# ─── Helios Installer Environment Variables ──────────────────────────────────
# Copy this file to ~/.pi/agent/.env and fill in your values.
# All variables have sensible defaults — only override what you need.

# ─── Memgraph ────────────────────────────────────────────────────────────────
# Credentials for the Memgraph graph database.
# Defaults are used if unset; change these for production deployments.
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=memgraph

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Local AI model runtime URL (default: localhost)
OLLAMA_URL=http://localhost:11434

# ─── AWS / Bedrock (optional — only if using Amazon Bedrock provider) ────────
# Get credentials from: AWS Console → IAM → Security Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ─── API Keys (optional — managed via macOS Keychain when available) ─────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
