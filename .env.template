# =============================================================================
# Helios + Pi Environment Variables Template
# =============================================================================
# Copy this file to ~/.pi/agent/.env and fill in your values.
# The installer will generate .env from this template interactively.
#
# NEVER commit .env to version control.
# =============================================================================

# ─── Required — at least one AI provider ──────────────────────────────────────

# Anthropic Claude API (recommended for getting started)
# Get your key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# OpenAI API (optional — for GPT models)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Amazon Bedrock (if using Bedrock provider) ───────────────────────────────
# Configure AWS CLI first: `aws configure`
# Or set credentials here directly:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ─── GitHub (recommended for PR review, MCP server) ──────────────────────────
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=

# ─── Optional Integrations ────────────────────────────────────────────────────

# Figma MCP Server (for design-to-code workflows)
# Get your token at: https://www.figma.com → Account Settings → API tokens
FIGMA_MCP_TOKEN=

# Groq API (for fast transcription via Whisper)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Brave Search API (for web search skill)
# Get your key at: https://api.search.brave.com/
BRAVE_API_KEY=

# ─── Memgraph (knowledge graph for session memory) ────────────────────────────
# Connection settings for your Memgraph instance
MEMGRAPH_HOST=127.0.0.1
MEMGRAPH_PORT=7687
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=memgraph

# ─── Ollama (local embeddings for semantic search) ────────────────────────────
OLLAMA_URL=http://localhost:11434
