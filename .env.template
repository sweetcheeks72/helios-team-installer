# Helios Service Keys (optional)
# ============================================================================
# AI provider auth is handled by Pi OAuth — run 'helios' to log in.
# These keys are for ancillary services only.
# ============================================================================

# GitHub token — for PR review via MCP server
# Get at: github.com/settings/tokens
GITHUB_TOKEN=

# Groq — for Whisper audio transcription
# Get at: console.groq.com
GROQ_API_KEY=

# Figma — for design MCP server
# Get at: figma.com → Account → API tokens
FIGMA_MCP_TOKEN=

# ─── Infrastructure overrides (optional) ──────────────────────────────────────
# Defaults work out of the box. Only set these if using non-standard ports.

# Ollama — local LLM server (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Memgraph — managed via runtime/memgraph.env (not here)
# Override in ~/.pi/agent/mcp.json if using non-default host/port
