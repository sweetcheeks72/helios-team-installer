{
  "assistantName": "Helios",
  "defaultProvider": "openai",
  "defaultModel": "gpt-5.2",
  "enableSkillCommands": true,
  "hideThinkingBlock": false,
  "quietStartup": true,
  "enabledModels": [
    "openai/gpt-5.2",
    "openai/gpt-4o",
    "openai/gpt-4o-mini",
    "anthropic/claude-sonnet-4-5-20250514",
    "anthropic/claude-haiku-4-5-20241022",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex",
    "openai-codex/gpt-5.2-codex",
    "openai-codex/gpt-5.1",
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-opus-4-6",
    "anthropic/claude-haiku-4-5"
  ],
  "skills": [
    "~/.pi/agent/skills",
    "~/.familiar/skills"
  ],
  "packages": [
    "npm:pi-mcp-adapter",
    "git:github.com/nicobailon/pi-subagents",
    "git:github.com/sweetcheeks72/pi-messenger",
    "git:github.com/nicobailon/pi-coordination",
    "git:github.com/nicobailon/pi-model-switch",
    "git:github.com/nicobailon/pi-powerline-footer",
    "git:github.com/nicobailon/pi-prompt-template-model",
    "git:github.com/nicobailon/pi-review-loop",
    "git:github.com/nicobailon/pi-rewind-hook",
    "git:github.com/nicobailon/pi-web-access",
    "git:github.com/nicobailon/pi-interactive-shell",
    "git:github.com/nicobailon/pi-design-deck",
    "git:github.com/nicobailon/visual-explainer",
    "git:github.com/nicobailon/surf-cli",
    "git:github.com/nicobailon/pi-foreground-chains",
    "git:github.com/nicobailon/skills-hook",
    "git:github.com/nicobailon/pi-interview-tool",
    "git:github.com/nicobailon/pi-annotate",
    "git:github.com/nicobailon/pi-skill-palette",
    "git:github.com/nicobailon/pi-boomerang"
  ],
  "extensions": [
